# Anthropic (required)
GROQ_API_KEY=gsk-your-groq-api-key-here

# Database (required)
DATABASE_URL=postgresql+asyncpg://postgres:lifeos@localhost:5433/lifeos

# Redis (required)
REDIS_URL=redis://localhost:6379

# Chroma (required for self-hosted Mem0)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Tavily (required for research/delegate agents)
TAVILY_API_KEY=tvly-...

# Clerk Authentication
# Get these from your Clerk Dashboard: https://dashboard.clerk.com
# JWKS URL format: https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
CLERK_SECRET_KEY=sk_test_... or sk_live_...
CLERK_PUBLISHABLE_KEY=pk_test_... or pk_live_...
CLERK_WEBHOOK_SECRET=whsec_...  # optional

# App
ENVIRONMENT=development
DEBUG=true
